# ── LLM ──────────────────────────────────────────────────────────────────────
# Swap provider by changing these 3 lines — no code changes needed
LLM_API_KEY= "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"
LLM_BASE_URL= "https://api.openai.com/v1"
LLM_MODEL=  "gpt-4o"

# ── Embeddings ────────────────────────────────────────────────────────────────
# Any HuggingFace sentence-transformers model works here
EMBED_MODEL_NAME=sentence-transformers/all-mpnet-base-v2   # 768-dim (default)
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2  # 384-dim (faster)
# EMBED_MODEL_NAME=sentence-transformers/all-roberta-large-v1  # 1024-dim (more accurate)
EMBED_DIM=768   # must match the model above

# ── Ranking ───────────────────────────────────────────────────────────────────
TOP_K_FOR_LLM=10      # how many top CVs go to the LLM for deep scoring
WEIGHT_SIM=0.3        # weight for embedding similarity score
WEIGHT_LLM=0.7        # weight for LLM score  (WEIGHT_SIM + WEIGHT_LLM must = 1.0)
MAX_ROUNDS=3          # max human-in-the-loop feedback rounds

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=quantahire

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
RAG_STORAGE=rag_storage
